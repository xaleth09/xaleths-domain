{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "xaleths-domain",
  "main": "worker/index.js",
  "compatibility_date": "2026-05-22",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
